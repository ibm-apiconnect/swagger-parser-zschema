{
  "openapi": "3.0.0",
  "info": {
    "title": "OIDC Security API",
    "x-ibm-name": "oidc-security-api",
    "description": "API with OpenID Connect security for testing",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.example.com"
    }
  ],
  "x-ibm-configuration": {
    "cors": {
      "enabled": true
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true
  },
  "paths": {
    "/user": {
      "get": {
        "summary": "Get user information",
        "description": "Returns user information",
        "operationId": "getUser",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "oidc_auth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oidc_auth": {
        "type": "openIdConnect",
        "openIdConnectUrl": "https://example.com/.well-known/openid-configuration"
      }
    }
  }
}
