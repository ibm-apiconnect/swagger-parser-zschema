{
  "openapi": "3.1.0",
  "info": {
    "title": "Webhook Examples API",
    "version": "1.0.0"
  },
  "paths": {
    "/test": {
      "get": {
        "responses": {
          "200": {
            "description": "test",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "example1": {
                    "summary": "An example with Alice",
                    "value": {
                      "user": "Alice"
                    }
                  },
                  "example2": {
                    "summary": "An example with Bob",
                    "value": {
                      "user": "Bob"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "userUpdate": {
      "post": {
        "requestBody": {
          "description": "Webhook triggered when user updates",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "string" },
                  "status": { "type": "string" }
                },
                "required": ["userId", "status"],
                "examples": {
                  "example1": {
                    "value": {
                      "userId": "123",
                      "status": "active"
                    }
                  },
                  "example2": {
                    "value": {
                      "userId": "456",
                      "status": "inactive"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook received successfully"
          }
        }
      }
    }
  }
}
