{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "OAuth Security (Open API v3)",
    "description": "X-ibm-config Oauth servers test api",
    "contact": {
      "name": "John Doe",
      "email": "john.doe@example.com",
      "url": "https://www.example.com"
    },
    "termsOfService": "https://www.example.com/terms"
  },
  "x-ibm-configuration": {
    "oauth-servers": {
      "native": {
        "authorizationCode": {
          "tokenUrls": ["https://localhost:8080/alpha/oauth2/token", "https://example.com/oauth2/token"],
          "authorizationUrls": ["https://localhost:8080/alpha/oauth2/authorize", "https://example.com/oauth2/authorize"],
          "refreshUrls": ["https://localhost:8080/refresh"]
        }
      },
      "tpp": {
        "implicit": {
          "authorizationUrls": ["https://thirdparty.com/oauth2/authorize"],
          "refreshUrls": []
        }
      }
    },
    "cors": {
      "enabled": true
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true,
    "application-authentication": {
      "certificate": false
    },
    "servers": [
      {
        "url": "https://localhost:8080",
        "description": "",
        "type": ["Production", "Development"]
      },
      {
        "url": "https://example.com",
        "description": "",
        "type": ["Production", "Development"]
      }
    ]
  },
  "paths": {
    "/basepath": {
      "get": {
        "summary": "Put a specific item from the database",
        "description": "Put a specific item from the database",
        "responses": {
          "204": {
            "description": "Successful delete"
          }
        }
      }
    }
  },
  "security": [
    {
      "native": []
    },
    {
      "tpp": []
    }
  ],
  "x-ibm-endpoints": [
    {
      "endpointUrl": "http://example.com:8080",
      "type": ["development", "production"]
    }
  ],
  "components": {
    "securitySchemes": {
      "native": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://petstore3.swagger.io/oauth/authorize",
            "scopes": {
              "write:pets": "modify pets in your account",
              "read:pets": "read your pets"
            }
          }
        },
        "x-key-type": "clientId"
      },
      "tpp": {
        "type": "oauth2",
        "flows": {
          "implicit": {
            "authorizationUrl": "https://petstore3.swagger.io/oauth/authorize",
            "scopes": {
              "write:pets": "modify pets in your account",
              "read:pets": "read your pets"
            }
          }
        },
        "x-key-type": "clientId"
      }
    }
  }
}
