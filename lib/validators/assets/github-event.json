{
  "openapi": "3.1.0",
  "info": {
    "title": "Github Events",
    "description": "Demonstrates multiple webhooks for common GitHub-style events.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.github.com",
      "description": "GitHub Public API"
    }
  ],
  "paths": {
    "/users/{username}": {
      "get": {
        "summary": "Get a GitHub user",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "GitHub username"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful user fetch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "onPush": {
      "post": {
        "summary": "Triggered when a push event occurs",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push webhook received"
          }
        }
      }
    },
    "onIssues": {
      "post": {
        "summary": "Triggered when an issue is opened or edited",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue webhook received"
          }
        }
      }
    },
    "onPullRequest": {
      "post": {
        "summary": "Triggered when a pull request is created or updated",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PullRequestEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pull request webhook received"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "avatar_url": {
            "type": "string",
            "format": "uri"
          },
          "html_url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["login", "id"]
      },
      "PushEvent": {
        "type": "object",
        "properties": {
          "ref": { "type": "string" },
          "before": { "type": "string" },
          "after": { "type": "string" },
          "repository": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "full_name": { "type": "string" }
            },
            "required": ["id", "name"]
          },
          "pusher": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            },
            "required": ["name"]
          }
        },
        "required": ["ref", "before", "after", "repository", "pusher"]
      },
      "IssueEvent": {
        "type": "object",
        "properties": {
          "action": { "type": "string" },
          "issue": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "title": { "type": "string" },
              "body": { "type": "string" },
              "state": { "type": "string" }
            },
            "required": ["id", "title"]
          },
          "repository": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            },
            "required": ["id", "name"]
          }
        },
        "required": ["action", "issue", "repository"]
      },
      "PullRequestEvent": {
        "type": "object",
        "properties": {
          "action": { "type": "string" },
          "number": { "type": "integer" },
          "pull_request": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "title": { "type": "string" },
              "state": { "type": "string" },
              "merged": { "type": "boolean" }
            },
            "required": ["id", "title", "state"]
          },
          "repository": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            },
            "required": ["id", "name"]
          }
        },
        "required": ["action", "number", "pull_request", "repository"]
      }
    }
  }
}
