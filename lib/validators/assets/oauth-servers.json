{
  "swagger": "2.0",
  "info": {
    "title": "Oauth servers security",
    "x-ibm-name": "oauth-servers-security",
    "version": "1.0.0"
  },
  "schemes": ["https"],
  "basePath": "/ibmsec/",
  "security": [
    {
      "native": []
    },
    {
      "tpp": []
    }
  ],
  "securityDefinitions": {
    "native": {
      "type": "oauth2",
      "flow": "application",
      "x-ibm-oauth-provider": "nativeoauth",
      "tokenUrl": "/oauth2/token",
      "authorizationUrl": "/oauth2/auth"
    },
    "tpp": {
      "type": "oauth2",
      "flow": "application",
      "x-ibm-oauth-provider": "nativeoauth",
      "tokenUrl": "/oauth2/token",
      "authorizationUrl": "/oauth2/auth"
    }
  },
  "x-ibm-configuration": {
    "oauth-servers": {
      "native": {
        "tokenUrls": ["https://localhost:8080/alpha/oauth2/token", "https://example.com/oauth2/token"],
        "authorizationUrls": ["https://localhost:8080/alpha/oauth2/authorize", "https://example.com/oauth2/authorize"],
        "refreshUrls": ["https://localhost:8080/refresh"]
      },
      "tpp": {
        "tokenUrls": ["https://thirdparty.com/oauth2/token"],
        "authorizationUrls": ["https://thirdparty.com/oauth2/authorize"],
        "refreshUrls": []
      }
    },
    "cors": {
      "enabled": true
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true,
    "application-authentication": {
      "certificate": false
    },
    "servers": [
      {
        "url": "https://localhost:8080",
        "description": "",
        "type": ["Production", "Development"]
      },
      {
        "url": "https://example.com",
        "description": "",
        "type": ["Production", "Development"]
      }
    ]
  },
  "paths": {
    "/status": {
      "get": {
        "responses": {
          "200": {
            "description": "success",
            "schema": {
              "type": "string"
            }
          }
        },
        "consumes": [],
        "produces": []
      },
      "parameters": []
    }
  },
  "host": "localhost:8080"
}
