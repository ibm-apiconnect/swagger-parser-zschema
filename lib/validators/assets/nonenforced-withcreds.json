  "produces": ["application/json"],
  "securityDefinitions": {
    "password": {
      "type": "oauth2",
      "description": "",
      "flow": "password",
      "scopes": {
        "ip": "desc",
        "another": "desc1"
      },
      "tokenUrl": "https://example.com/jdoe/sb/oauth-provider/oauth2/token"
    },
    "application": {
      "type": "oauth2",
      "description": "",
