        "responses": {
          "200": {
            "description": "200 OK"
          }
        }
      }
    },
    "/headers": {
      "get": {
        "responses": {
          "200": {
            "description": "200 OK"
          }
        }
      },
      "parameters": [
        {
          "name": "test-header",
          "type": "string",
          "required": true,
