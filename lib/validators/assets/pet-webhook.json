{
  "openapi": "3.1.0",
  "info": {
    "title": "Pet API",
    "version": "1.0.0",
    "description": "Easy example of documentation with a single webhook, provided by OpenAPI Initiative.\n"
  },
  "paths": {
    "/pets/{petId}": {
      "get": {
        "summary": "Get pet details",
        "description": "Retrieve details of a specific pet by ID.",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns pet details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "newPet": {
      "post": {
        "description": "A new pet is born, let's come and discover it in Petstore.",
        "parameters": [
          {
            "name": "X-Webhook-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the webhook event"
          },
          {
            "name": "X-Signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "HMAC signature for webhook verification"
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Unix timestamp of the event"
          }
        ],
        "requestBody": {
          "description": "Information about a new pet in the system",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pet"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return a 200 status to indicate that the data was received successfully"
          },
          "404": {
            "description": "Item not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "exclusiveMinimum": 10,
            "exclusiveMaximum": 15
          },
          "name": {
            "type": ["string", "null"],
            "const": "Bob"
          },
          "tag": {
            "type": "string",
            "nullable": true
          },
          "iban": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    }
  }
}
